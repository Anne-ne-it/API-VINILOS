// Este es tu archivo de esquema de Prisma, más sobre él en la documentación: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model product {
  id Int @id @default(autoincrement())
  title String
  author String?
  price Float?
  stock Int?
  createAt DateTime @default(now()) @map("created_at")

  @@map("products")
}

model User {
  id Int @id @default(autoincrement())
  email String @unique
  password String
  role String @default("user")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}